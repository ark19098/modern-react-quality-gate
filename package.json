{
	"name": "linting-biome",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"test": "vitest run",
		"preview": "vite preview",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{js,ts,jsx,tsx}": [
			"biome check --write",
			"vitest related --run"
		]
	},
	"dependencies": {
		"react": "^19.2.5",
		"react-dom": "^19.2.5"
	},
	"devDependencies": {
		"@babel/core": "^7.29.0",
		"@biomejs/biome": "^2.4.15",
		"@eslint/js": "^10.0.1",
		"@rolldown/plugin-babel": "^0.2.3",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/babel__core": "^7.20.5",
		"@types/node": "^24.12.2",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"babel-plugin-react-compiler": "^1.0.0",
		"eslint": "^10.2.1",
		"eslint-plugin-react-hooks": "^7.1.1",
		"eslint-plugin-react-refresh": "^0.5.2",
		"globals": "^17.5.0",
		"husky": "^9.1.7",
		"jsdom": "^29.1.1",
		"lint-staged": "^17.0.4",
		"typescript": "~6.0.2",
		"typescript-eslint": "^8.58.2",
		"vite": "^8.0.10",
		"vitest": "^4.1.5"
	}
}
